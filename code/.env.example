# AutonoMind 环境配置示例
# 复制此文件为 .env 并根据实际情况修改配置

# ========== 应用配置 ==========
APP_NAME=AutonoMind
APP_VERSION=0.1.0
DEBUG=true
ENVIRONMENT=development

# ========== 服务器配置 ==========
HOST=0.0.0.0
PORT=8000
WORKERS=1

# ========== 数据库配置 ==========
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=autonomind
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# ========== Redis配置 ==========
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_MAX_CONNECTIONS=50

# ========== Qdrant向量数据库配置 ==========
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_COLLECTION_PREFIX=autonomind

# ========== RabbitMQ配置 ==========
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# ========== MinIO对象存储配置 ==========
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET_PREFIX=autonomind

# ========== LLM配置 ==========
# 使用OpenAI官方API
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4-turbo-preview

# 或者使用DeepSeek等其他兼容OpenAI接口的服务
# OPENAI_API_BASE=https://api.deepseek.com/v1
# OPENAI_API_KEY=your-deepseek-api-key
# OPENAI_MODEL=deepseek-chat

OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=4096

# ========== Celery配置 ==========
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ========== JWT配置 ==========
# 生产环境请务必修改为强密码
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ========== 日志配置 ==========
LOG_LEVEL=INFO
LOG_DIR=logs

# ========== CORS配置 ==========
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ========== 文件上传配置 ==========
UPLOAD_MAX_SIZE=10485760

# ========== 向量嵌入配置 ==========
EMBEDDING_MODEL=text-embedding-ada-002
EMBEDDING_DIMENSION=1536

# ========== 智能体配置 ==========
AGENT_MAX_CONVERSATION_LENGTH=50
AGENT_MAX_CONTEXT_TOKENS=8000
AGENT_MEMORY_RETENTION_DAYS=30
AGENT_AUTO_EVOLUTION_ENABLED=true
AGENT_EVOLUTION_CHECK_INTERVAL_HOURS=24
